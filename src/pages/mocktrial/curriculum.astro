---
import Layout from '../../layouts/Layout.astro'

const sessions = [
  {
    num: "01",
    title: "Kick-Off",
    desc: "Program goals, expectations, and case file distribution. Students form teams, receive their roles, and get oriented to the case materials.",
  },
  {
    num: "02",
    title: "Case Analysis",
    desc: "How to dissect a case file and organize its parts. Students learn to identify key facts, legal elements, and build a theory of the case from raw materials.",
  },
  {
    num: "03",
    title: "Opening Statements",
    desc: "Structure, purpose, and what makes an opening persuasive. Students draft and deliver their first opening statements with peer and coach feedback.",
  },
  {
    num: "04",
    title: "Direct Examination",
    desc: "Drawing out testimony through strategic questioning. Students learn to prepare witnesses and develop testimony that supports their theory of the case.",
  },
  {
    num: "05",
    title: "Cross-Examination",
    desc: "Challenging witnesses and controlling the narrative. Students practice the art of leading questions, impeachment, and thinking on their feet.",
  },
  {
    num: "06",
    title: "Closing Arguments",
    desc: "Weaving facts and testimony into a compelling final pitch. Students learn to tie evidence to legal standards and leave a lasting impression.",
  },
  {
    num: "07",
    title: "Evidence & Objections",
    desc: "Rules of evidence appropriately scaled for high school competition. Foundational objections, exhibit handling, and courtroom procedure.",
  },
  {
    num: "08",
    title: "Competition",
    desc: "Blues vs. Bay Area schools. Students put everything together in a live competitive round with real judges, real scoring, and real stakes.",
  },
]
---

<Layout title="Curriculum — Mock Trial at Urban" description="Session-by-session breakdown of the Mock Trial at Urban program.">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <p class="text-xs font-semibold uppercase tracking-[3px] text-urban-blue mb-4">
      <a href="/mocktrial" class="hover:text-ink transition-colors">&larr; Mock Trial at Urban</a>
    </p>
    <h1 class="font-heading text-4xl font-black mb-4">Session-by-Session Curriculum</h1>
    <p class="text-lg text-ink-light mb-12">
      Eight sessions that build progressively from case analysis through live competition. Each week layers new skills on the last — by the end, students are running a full trial.
    </p>

    <div class="space-y-6">
      {sessions.map((s) => (
        <div class="flex gap-5 items-start">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-urban-slate flex items-center justify-center text-sm font-bold text-urban-blue">
            {s.num}
          </span>
          <div>
            <h3 class="font-bold text-ink mb-1">{s.title}</h3>
            <p class="text-sm text-ink-light leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-14 bg-urban-blue text-white rounded-xl p-8">
      <h2 class="font-heading text-xl font-bold text-gold mb-4">Competition Track</h2>
      <div class="text-sm text-white/70 leading-relaxed space-y-2">
        <p><strong class="text-white">Fall:</strong> Case prep through sessions 1–7. Skills building, full trial run-throughs, and potential friendly scrimmages with other SF schools as we prepare for competition.</p>
        <p><strong class="text-white">Winter:</strong> Continued practice, scrimmages, and SF County Mock Trial competition (January–February). This is the main event — the Blues compete against schools across San Francisco.</p>
        <p><strong class="text-white">Spring (TBD):</strong> Second case and competition opportunity to be determined based on team interest and available tournaments.</p>
      </div>
    </div>

    <div class="mt-10 flex justify-center gap-6 text-sm">
      <a href="/mocktrial/parents" class="font-semibold text-urban-blue hover:text-ink transition-colors underline underline-offset-2">
        Parent Information &rarr;
      </a>
      <a href="/mocktrial#register" class="font-semibold text-urban-blue hover:text-ink transition-colors underline underline-offset-2">
        Register Your Interest &rarr;
      </a>
    </div>
  </section>
</Layout>
