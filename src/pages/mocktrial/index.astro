---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Mock Trial — Urban School of San Francisco" description="A new elective where students learn to think on their feet, argue with evidence, and compete.">
  <!-- Hero -->
  <section class="bg-dark text-cream">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24 text-center">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-earth-light mb-4">The Urban School of San Francisco</p>
      <h1 class="font-heading text-5xl md:text-6xl font-black text-gold leading-tight mb-3">
        Make Your Case.
      </h1>
      <p class="text-lg md:text-xl font-heading font-bold uppercase tracking-widest text-cream mb-6">
        Urban School Mock Trial
      </p>
      <p class="text-lg text-earth-light max-w-xl mx-auto">
        A new elective where you learn to think on your feet, argue with evidence, and compete.
      </p>
    </div>
  </section>

  <!-- What Is It -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <div class="bg-cream-dark rounded-2xl p-8 text-center">
      <p class="text-lg leading-relaxed text-ink-light">
        Mock trial is <strong class="text-ink">courtroom competition</strong> — you play lawyers and witnesses in a realistic trial.
        Build a case from the ground up, present it to a judge, and go head-to-head against another school.
        No experience needed. <strong class="text-warm">Just bring your voice.</strong>
      </p>
    </div>
  </section>

  <!-- Skills Grid -->
  <section class="max-w-4xl mx-auto px-6 pb-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x1f5e3;&#xfe0f;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Speak Up</h3>
        <p class="text-sm text-ink-light">Public speaking that actually feels real</p>
      </div>
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x1f9e0;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Think Sharp</h3>
        <p class="text-sm text-ink-light">Analyze facts, spot weaknesses, build arguments</p>
      </div>
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x1f91d;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Team Up</h3>
        <p class="text-sm text-ink-light">Win as a team — every role matters</p>
      </div>
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x26a1;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Compete</h3>
        <p class="text-sm text-ink-light">Real competitions against real schools</p>
      </div>
    </div>
  </section>

  <!-- Your Arc -->
  <section class="bg-dark text-cream">
    <div class="max-w-4xl mx-auto px-6 py-14">
      <h2 class="font-heading text-2xl font-bold text-gold text-center mb-10">Your Arc</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">1</div>
          <h4 class="font-bold text-sm mb-1">Get the Case</h4>
          <p class="text-xs text-earth-light">Receive your case file &amp; learn to break it down</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">2</div>
          <h4 class="font-bold text-sm mb-1">Build Skills</h4>
          <p class="text-xs text-earth-light">Openings, directs, crosses, closings, objections</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">3</div>
          <h4 class="font-bold text-sm mb-1">Run the Trial</h4>
          <p class="text-xs text-earth-light">Practice rounds — full trial simulations</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">4</div>
          <h4 class="font-bold text-sm mb-1">Compete!</h4>
          <p class="text-xs text-earth-light">Local competition against other schools</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Logistics -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <h2 class="font-heading text-2xl font-bold text-ink mb-8 text-center">Details</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-cream-dark rounded-xl p-6">
        <h3 class="text-xs font-bold uppercase tracking-wider text-earth mb-3">Schedule</h3>
        <div class="text-sm text-ink-light leading-relaxed space-y-1">
          <p><strong class="text-ink">When:</strong> Tuesdays during You Period</p>
          <p><strong class="text-ink">Terms:</strong> Fall &amp; Winter trimesters</p>
          <p><strong class="text-ink">Spring:</strong> Second case &amp; competition (TBD)</p>
          <p><strong class="text-ink">Competition:</strong> Local invitational (~November)</p>
        </div>
      </div>
      <div class="bg-cream-dark rounded-xl p-6">
        <h3 class="text-xs font-bold uppercase tracking-wider text-earth mb-3">Who</h3>
        <div class="text-sm text-ink-light leading-relaxed space-y-1">
          <p><strong class="text-ink">Size:</strong> 8–12 students</p>
          <p><strong class="text-ink">Grades:</strong> Sophomores, Juniors &amp; Seniors preferred; Freshmen welcome</p>
          <p><strong class="text-ink">Experience:</strong> None required</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coach -->
  <section class="max-w-3xl mx-auto px-6 pb-14">
    <div class="border border-cream-dark rounded-xl p-6">
      <h3 class="text-xs font-bold uppercase tracking-wider text-earth mb-3">Your Coach</h3>
      <p class="text-sm text-ink-light leading-relaxed">
        <strong class="text-ink">Erik Knuppel</strong> — Former trial and appellate attorney. 10+ years teaching trial advocacy at UC Law San Francisco and Golden Gate Law. 20+ competition teams coached at the national level. Founded GavelStats, a mock trial analytics platform used by the ABA and law schools nationwide.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-ink text-cream">
    <div class="max-w-3xl mx-auto px-6 py-12 text-center">
      <h2 class="font-heading text-2xl font-bold text-gold mb-3">Interested?</h2>
      <p class="text-earth-light mb-6">Talk to Skyler Silverman to sign up or learn more.</p>
      <a href="mailto:ssilverman@urbanschool.org" class="inline-block bg-gold text-ink font-bold text-sm px-8 py-3 rounded-lg hover:bg-gold-dim transition-colors">
        ssilverman@urbanschool.org
      </a>
      <div class="mt-6 flex justify-center gap-6 text-sm text-earth-light">
        <a href="/mocktrial/parents" class="hover:text-cream transition-colors underline underline-offset-2">Parent Info &rarr;</a>
        <a href="/mocktrial/curriculum" class="hover:text-cream transition-colors underline underline-offset-2">Full Curriculum &rarr;</a>
      </div>
    </div>
  </section>
</Layout>
