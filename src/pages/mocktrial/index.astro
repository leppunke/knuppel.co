---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Mock Trial — Urban School of San Francisco" description="A new elective where students learn to think on their feet, argue with evidence, and compete. Fall 2026.">
  <!-- Hero -->
  <section class="bg-dark text-cream">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24 text-center">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-earth-light mb-4">The Urban School of San Francisco</p>
      <h1 class="font-heading text-5xl md:text-6xl font-black text-gold leading-tight mb-3">
        Make Your Case.
      </h1>
      <p class="text-lg md:text-xl font-heading font-bold uppercase tracking-widest text-cream mb-6">
        Urban School Mock Trial
      </p>
      <p class="text-lg text-earth-light max-w-xl mx-auto mb-8">
        A new elective where you learn to think on your feet, argue with evidence, and compete against other schools. Launching Fall 2026.
      </p>
      <a href="#register" class="inline-block bg-gold text-dark font-bold text-sm px-8 py-3 rounded-lg hover:bg-gold-dim transition-colors">
        Register Your Interest
      </a>
    </div>
  </section>

  <!-- What Is It -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <div class="bg-cream-dark rounded-2xl p-8 text-center">
      <p class="text-lg leading-relaxed text-ink-light">
        Mock trial is <strong class="text-ink">courtroom competition</strong> — you play lawyers and witnesses in a realistic trial.
        Build a case from the ground up, present it to a judge, and go head-to-head against another school.
        No experience needed. <strong class="text-warm">Just bring your voice.</strong>
      </p>
    </div>
  </section>

  <!-- Skills Grid -->
  <section class="max-w-4xl mx-auto px-6 pb-14">
    <h2 class="font-heading text-2xl font-bold text-ink text-center mb-8">What You'll Build</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x1f5e3;&#xfe0f;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Speak Up</h3>
        <p class="text-sm text-ink-light">Public speaking that actually feels real — argue in front of judges, not just classmates</p>
      </div>
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x1f9e0;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Think Sharp</h3>
        <p class="text-sm text-ink-light">Analyze facts, spot weaknesses, build arguments — then defend them under pressure</p>
      </div>
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x1f91d;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Team Up</h3>
        <p class="text-sm text-ink-light">Win as a team — every role matters, from lead attorney to key witness</p>
      </div>
      <div class="bg-cream-dark rounded-xl p-6 text-center">
        <div class="text-3xl mb-3">&#x26a1;</div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-warm mb-1">Compete</h3>
        <p class="text-sm text-ink-light">Real competitions against real schools — SF County Mock Trial and beyond</p>
      </div>
    </div>
  </section>

  <!-- Your Arc -->
  <section class="bg-dark text-cream">
    <div class="max-w-4xl mx-auto px-6 py-14">
      <h2 class="font-heading text-2xl font-bold text-gold text-center mb-10">Your Arc</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">1</div>
          <h4 class="font-bold text-sm mb-1">Get the Case</h4>
          <p class="text-xs text-earth-light">Receive your case file &amp; learn to break it down</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">2</div>
          <h4 class="font-bold text-sm mb-1">Build Skills</h4>
          <p class="text-xs text-earth-light">Openings, directs, crosses, closings, objections</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">3</div>
          <h4 class="font-bold text-sm mb-1">Run the Trial</h4>
          <p class="text-xs text-earth-light">Practice rounds — full trial simulations</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full border-2 border-gold text-gold font-bold text-sm mb-3">4</div>
          <h4 class="font-bold text-sm mb-1">Compete!</h4>
          <p class="text-xs text-earth-light">Local competition against other schools</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Logistics -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <h2 class="font-heading text-2xl font-bold text-ink mb-8 text-center">Details</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-cream-dark rounded-xl p-6">
        <h3 class="text-xs font-bold uppercase tracking-wider text-earth mb-3">Schedule</h3>
        <div class="text-sm text-ink-light leading-relaxed space-y-1">
          <p><strong class="text-ink">When:</strong> Tuesdays during You Period</p>
          <p><strong class="text-ink">Terms:</strong> Fall &amp; Winter trimesters</p>
          <p><strong class="text-ink">Spring:</strong> Second case &amp; competition (TBD)</p>
          <p><strong class="text-ink">Competition:</strong> SF County Mock Trial (January–February)</p>
        </div>
      </div>
      <div class="bg-cream-dark rounded-xl p-6">
        <h3 class="text-xs font-bold uppercase tracking-wider text-earth mb-3">Who</h3>
        <div class="text-sm text-ink-light leading-relaxed space-y-1">
          <p><strong class="text-ink">Size:</strong> 8–12 students</p>
          <p><strong class="text-ink">Grades:</strong> Sophomores, Juniors &amp; Seniors preferred; Freshmen welcome</p>
          <p><strong class="text-ink">Experience:</strong> None required</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coach -->
  <section class="max-w-3xl mx-auto px-6 pb-14">
    <div class="border border-cream-dark rounded-xl p-6">
      <h3 class="text-xs font-bold uppercase tracking-wider text-earth mb-3">Your Coach</h3>
      <p class="text-sm text-ink-light leading-relaxed">
        <strong class="text-ink">Erik Knuppel</strong> — Former trial and appellate attorney. 10+ years teaching trial advocacy at UC Law San Francisco and Golden Gate Law. 20+ competition teams coached at the national level, including ABA Nationals and the TYLA National Trial Competition. Founded GavelStats, a mock trial analytics platform used by the ABA and law schools nationwide.
      </p>
    </div>
  </section>

  <!-- Why Mock Trial (for parents scanning) -->
  <section class="max-w-3xl mx-auto px-6 pb-14">
    <div class="bg-ink text-cream rounded-2xl p-8">
      <h2 class="font-heading text-xl font-bold text-gold mb-5">Why Mock Trial Matters</h2>
      <div class="grid md:grid-cols-2 gap-3">
        <p class="text-sm text-earth-light pl-5 relative before:content-['→'] before:absolute before:left-0 before:text-gold before:font-bold">Builds confidence speaking in high-pressure situations</p>
        <p class="text-sm text-earth-light pl-5 relative before:content-['→'] before:absolute before:left-0 before:text-gold before:font-bold">Strengthens analytical writing and reasoning skills</p>
        <p class="text-sm text-earth-light pl-5 relative before:content-['→'] before:absolute before:left-0 before:text-gold before:font-bold">Teaches evidence-based argumentation — a lifelong skill</p>
        <p class="text-sm text-earth-light pl-5 relative before:content-['→'] before:absolute before:left-0 before:text-gold before:font-bold">Strong extracurricular for college applications</p>
        <p class="text-sm text-earth-light pl-5 relative before:content-['→'] before:absolute before:left-0 before:text-gold before:font-bold">Develops poise, listening, and quick thinking</p>
        <p class="text-sm text-earth-light pl-5 relative before:content-['→'] before:absolute before:left-0 before:text-gold before:font-bold">Fosters teamwork and leadership across grade levels</p>
      </div>
      <div class="mt-6 text-center">
        <a href="/mocktrial/parents" class="text-sm text-gold hover:text-cream transition-colors underline underline-offset-2">More for parents &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Registration Form -->
  <section id="register" class="bg-dark text-cream">
    <div class="max-w-xl mx-auto px-6 py-16">
      <h2 class="font-heading text-3xl font-bold text-gold text-center mb-3">Register Your Interest</h2>
      <p class="text-earth-light text-center mb-10">Spots are limited to 8–12 students. Sign up to stay in the loop as we finalize the roster for Fall 2026.</p>

      <form id="registration-form" class="space-y-5">
        <div>
          <label for="reg-name" class="block text-sm font-medium text-earth-light mb-1">Your Name</label>
          <input type="text" id="reg-name" name="name" required
            class="w-full px-4 py-3 rounded-lg bg-cream text-ink text-sm focus:outline-none focus:ring-2 focus:ring-gold"
            placeholder="First and last name" />
        </div>

        <div>
          <label for="reg-email" class="block text-sm font-medium text-earth-light mb-1">Email</label>
          <input type="email" id="reg-email" name="email" required
            class="w-full px-4 py-3 rounded-lg bg-cream text-ink text-sm focus:outline-none focus:ring-2 focus:ring-gold"
            placeholder="you@email.com" />
        </div>

        <div>
          <label class="block text-sm font-medium text-earth-light mb-2">I am a...</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="role" value="student" required class="accent-gold" />
              <span class="text-sm">Student</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="role" value="parent" class="accent-gold" />
              <span class="text-sm">Parent</span>
            </label>
          </div>
        </div>

        <div id="grade-field" class="hidden">
          <label for="reg-grade" class="block text-sm font-medium text-earth-light mb-1">Grade (Fall 2026)</label>
          <select id="reg-grade" name="grade"
            class="w-full px-4 py-3 rounded-lg bg-cream text-ink text-sm focus:outline-none focus:ring-2 focus:ring-gold">
            <option value="">Select grade</option>
            <option value="Freshman">Freshman</option>
            <option value="Sophomore">Sophomore</option>
            <option value="Junior">Junior</option>
            <option value="Senior">Senior</option>
          </select>
        </div>

        <div>
          <label for="reg-message" class="block text-sm font-medium text-earth-light mb-1">Anything else? <span class="text-earth">(optional)</span></label>
          <textarea id="reg-message" name="message" rows="3"
            class="w-full px-4 py-3 rounded-lg bg-cream text-ink text-sm focus:outline-none focus:ring-2 focus:ring-gold resize-none"
            placeholder="Questions, what excites you about mock trial, etc."></textarea>
        </div>

        <button type="submit" id="submit-btn"
          class="w-full bg-gold text-dark font-bold text-sm py-3 rounded-lg hover:bg-gold-dim transition-colors">
          Sign Me Up
        </button>

        <div id="form-message" class="text-center text-sm hidden"></div>
      </form>
    </div>
  </section>

  <!-- Footer Links -->
  <section class="max-w-3xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row justify-center gap-6 text-sm text-center">
      <a href="/mocktrial/parents" class="text-warm hover:text-ink transition-colors font-semibold underline underline-offset-2">Parent Information &rarr;</a>
      <a href="/mocktrial/curriculum" class="text-warm hover:text-ink transition-colors font-semibold underline underline-offset-2">Full Curriculum &rarr;</a>
      <a href="mailto:ssilverman@urbanschool.org" class="text-warm hover:text-ink transition-colors font-semibold underline underline-offset-2">Contact Skyler Silverman</a>
    </div>
  </section>

  <script>
    const form = document.getElementById('registration-form') as HTMLFormElement;
    const gradeField = document.getElementById('grade-field')!;
    const formMessage = document.getElementById('form-message')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    // Show grade field when student is selected
    form.querySelectorAll('input[name="role"]').forEach((radio) => {
      radio.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        gradeField.classList.toggle('hidden', target.value !== 'student');
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      formMessage.classList.add('hidden');

      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        role: formData.get('role'),
        grade: formData.get('grade') || null,
        message: formData.get('message') || null,
      };

      try {
        const res = await fetch('/api/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok) {
          form.innerHTML = `
            <div class="text-center py-8">
              <h3 class="font-heading text-2xl font-bold text-gold mb-3">You're on the list!</h3>
              <p class="text-earth-light">We'll be in touch as we finalize details for Fall 2026. Keep an eye on your inbox.</p>
            </div>
          `;
        } else {
          formMessage.textContent = result.error || 'Something went wrong.';
          formMessage.className = 'text-center text-sm text-red-400';
          formMessage.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Sign Me Up';
        }
      } catch {
        formMessage.textContent = 'Network error. Please try again.';
        formMessage.className = 'text-center text-sm text-red-400';
        formMessage.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Sign Me Up';
      }
    });
  </script>
</Layout>
