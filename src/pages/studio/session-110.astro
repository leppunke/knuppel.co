---
import Layout from '../../layouts/Layout.astro'

const images = [
  {
    "src": "/studio/session-110/01-the-second-chance-lounge-ed-zynka-behind-the-bar.png",
    "title": "The Second Chance Lounge — Ed Zynka Behind the Bar",
    "caption": "A shadowy tavern interior, patrons edging toward the exits. Behind the bar, a hard-eyed woman (Ed Zynka) in mercenary leathers, one hand resting beneath the counter, intricate red and blue tattoos winding around both arms beginning to glow."
  },
  {
    "src": "/studio/session-110/02-the-shield-guardians-manifest.png",
    "title": "The Shield Guardians Manifest",
    "caption": "Two massive metal constructs — one glowing red, one glowing blue — manifesting from ink tattoos that wind around a woman's arms, ink bleeding into full-sized shield guardians left and right of her. The bar around them erupts in shattering bottles and scattering patrons."
  },
  {
    "src": "/studio/session-110/03-toven-the-constrictor.png",
    "title": "Toven the Constrictor",
    "caption": "A druid mid-transformation into a massive constrictor snake, coiling through the wreckage of a tavern. The snake's body wraps around a human woman (Ed Zynka), dragging her across broken tables and shattered glass."
  },
  {
    "src": "/studio/session-110/04-toven-s-wall-of-stone-walkaway.png",
    "title": "Toven's Wall of Stone Walkaway",
    "caption": "A druid in a long coat walking casually away from the viewer, back to camera. Behind him, a freshly-conjured six-inch-thick wall of grey stone rising from the floor of a ruined tavern, sealing off a snarling woman and two shield guardians."
  },
  {
    "src": "/studio/session-110/05-commissar-lee-accepts-the-sword.png",
    "title": "Commissar Lee Accepts the Sword",
    "caption": "A grizzled stocky dwarf in Shield Bearer uniform, office cluttered with maps and weapons, reverently accepting an ornate ceremonial longsword from a small kobold paladin. Lee's chest plate is open to reveal a hardened gemstone embedded where a soul should live."
  },
  {
    "src": "/studio/session-110/06-sundr-at-the-sunweaver-temple.png",
    "title": "Sundr at the Sunweaver Temple",
    "caption": "An aasimar sorcerer standing in the center of an ornate gold-plated temple, surrounded by kneeling priests and shushed tourists. His body glows from within with inner radiance, light streaming through his skin."
  },
  {
    "src": "/studio/session-110/07-the-blood-spur-vision.png",
    "title": "The Blood Spur Vision",
    "caption": "A sweeping vision of a mountainous wasteland — jagged stone peaks and desolate valleys under a black, sunless sky. No plants, no life visible on the surface."
  },
  {
    "src": "/studio/session-110/08-twelve-the-rat.png",
    "title": "Twelve the Rat",
    "caption": "A single rat with a distended, pulsing brain visible through translucent skin at the top of its skull, the brain shifting through strange colors — purple, green, gold. The rat sits upright on a stone floor in the cranium rat nexus, other rats swarming in the background blurred out of focus."
  },
  {
    "src": "/studio/session-110/09-attuning-the-concordant-jewel.png",
